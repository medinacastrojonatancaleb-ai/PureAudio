{
  "entities": {
    "Like": {
      "title": "Like",
      "description": "Represents a user liking a track",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who liked the track" },
        "trackId": { "type": "string", "description": "The YouTube video ID" },
        "trackTitle": { "type": "string", "description": "The title of the track" },
        "trackArtist": { "type": "string", "description": "The artist of the track" },
        "trackThumbnail": { "type": "string", "description": "The thumbnail of the track" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the like was created" }
      },
      "required": ["userId", "trackId", "createdAt"]
    },
    "TrackStats": {
      "title": "TrackStats",
      "description": "Aggregated statistics for a track",
      "type": "object",
      "properties": {
        "likeCount": { "type": "integer", "description": "Total number of likes" }
      },
      "required": ["likeCount"]
    },
    "ArtistFollow": {
      "title": "ArtistFollow",
      "description": "Represents a user following an artist",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user" },
        "artistId": { "type": "string", "description": "The YouTube channel ID (if available)" },
        "artistName": { "type": "string", "description": "The name of the artist" },
        "artistThumbnail": { "type": "string", "description": "The thumbnail of the artist" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the follow was created" }
      },
      "required": ["userId", "artistName", "createdAt"]
    },
    "Download": {
      "title": "Download",
      "description": "Represents a track downloaded by a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user" },
        "trackId": { "type": "string", "description": "The YouTube video ID" },
        "trackTitle": { "type": "string", "description": "The title of the track" },
        "trackArtist": { "type": "string", "description": "The artist of the track" },
        "trackThumbnail": { "type": "string", "description": "The thumbnail of the track" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the download record was created" }
      },
      "required": ["userId", "trackId", "createdAt"]
    }
  },
  "firestore": {
    "/likes/{likeId}": {
      "schema": "Like",
      "description": "Collection of user likes"
    },
    "/trackStats/{trackId}": {
      "schema": "TrackStats",
      "description": "Counters for track interactions"
    },
    "/artistFollows/{followId}": {
      "schema": "ArtistFollow",
      "description": "Collection of artist follows"
    },
    "/downloads/{downloadId}": {
      "schema": "Download",
      "description": "Collection of user downloads"
    }
  }
}
